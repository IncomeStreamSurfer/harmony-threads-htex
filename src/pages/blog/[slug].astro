---
import Base from "../../layouts/Base.astro";
import { serverClient } from "../../lib/supabase";
import { safeHtml } from "../../lib/sanitize";

export const prerender = false;

const { slug } = Astro.params;
const sb = serverClient();

const { data: post } = await sb
  .from("content")
  .select("*")
  .eq("slug", slug!)
  .not("published_at", "is", null)
  .maybeSingle();

if (!post) return new Response("Not found", { status: 404 });

const blogSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.title,
  "datePublished": post.published_at,
  "author": { "@type": "Organization", "name": "Harmony Threads" },
  "publisher": { "@type": "Organization", "name": "Harmony Threads" },
  "description": post.seo_description || post.excerpt || "",
  "image": post.cover_image_url || "",
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": Astro.site?.toString() || "" },
    { "@type": "ListItem", "position": 2, "name": "Journal", "item": `${Astro.site || ""}blog` },
    { "@type": "ListItem", "position": 3, "name": post.title, "item": `${Astro.site || ""}blog/${post.slug}` },
  ],
};
---

<Base
  title={post.seo_title || `${post.title} | Harmony Threads`}
  description={post.seo_description || post.excerpt || ""}
  ogImage={post.cover_image_url || undefined}
  ogType="article"
  publishDate={post.published_at || undefined}
  tags={post.tags || []}
  structuredData={[blogSchema, breadcrumb]}
>
  <article class="max-w-3xl mx-auto px-6 py-20">
    <nav class="flex items-center gap-2 text-xs mb-12" style="color: var(--muted);">
      <a href="/" class="hover:text-[var(--accent)] transition-colors">Home</a>
      <span>/</span>
      <a href="/blog" class="hover:text-[var(--accent)] transition-colors">Journal</a>
      <span>/</span>
      <span class="truncate max-w-xs">{post.title}</span>
    </nav>
    {post.published_at && <p class="text-xs mb-4" style="color: var(--muted);">{new Date(post.published_at).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</p>}
    <h1 class="text-5xl font-bold leading-tight mb-6" style="font-family: 'Fraunces', serif;">{post.title}</h1>
    {post.excerpt && <p class="text-xl leading-relaxed mb-8 pb-8 border-b" style="color: var(--muted); border-color: var(--border);">{post.excerpt}</p>}
    {post.cover_image_url && <div class="rounded-2xl overflow-hidden mb-10"><img src={post.cover_image_url} alt={post.title} class="w-full" loading="lazy" /></div>}
    <div class="prose prose-lg max-w-none" set:html={safeHtml(post.body)} />
    <div class="mt-16 pt-8 border-t" style="border-color: var(--border);">
      <div class="flex gap-4 items-center justify-between">
        <a href="/blog" class="text-sm font-medium hover:text-[var(--accent)] transition-colors" style="color: var(--muted);">← Back to Journal</a>
        <a href="/shop" class="inline-flex items-center gap-2 px-6 py-3 rounded-lg text-white font-semibold text-sm transition-all hover:opacity-90" style="background: var(--accent);">Shop the collection →</a>
      </div>
    </div>
  </article>
</Base>
