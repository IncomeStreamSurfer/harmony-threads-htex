---
import Base from "../../layouts/Base.astro";
import { serverClient } from "../../lib/supabase";
import { safeHtml } from "../../lib/sanitize";

export const prerender = false;

const { slug } = Astro.params;
const sb = serverClient();

const { data: product } = await sb
  .from("products")
  .select("*, product_variants(*)")
  .eq("slug", slug!)
  .not("published_at", "is", null)
  .maybeSingle();

if (!product) {
  return new Response("Not found", { status: 404 });
}

const variants = (product.product_variants ?? []) as Array<{ id: string; sku: string; size: string; color: string; price_pence: number; inventory: number; image_url: string }>;
const sizes = [...new Set(variants.map((v) => v.size))].sort();
const colors = [...new Set(variants.map((v) => v.color))];

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": product.name,
  "description": product.description,
  "image": product.image_url || "",
  "brand": { "@type": "Brand", "name": "Harmony Threads" },
  "offers": {
    "@type": "Offer",
    "price": (product.price_pence / 100).toFixed(2),
    "priceCurrency": product.currency || "GBP",
    "availability": "https://schema.org/InStock",
    "seller": { "@type": "Organization", "name": "Harmony Threads" },
  },
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": Astro.site?.toString() || "" },
    { "@type": "ListItem", "position": 2, "name": "Shop", "item": `${Astro.site || ""}shop` },
    { "@type": "ListItem", "position": 3, "name": product.name, "item": `${Astro.site || ""}product/${product.slug}` },
  ],
};
---

<Base
  title={product.meta_title || `${product.name} | Harmony Threads`}
  description={product.meta_description || product.description || ""}
  ogImage={product.image_url || undefined}
  ogType="product"
  structuredData={[productSchema, breadcrumb]}
>
  <div class="max-w-7xl mx-auto px-6 py-16">
    <nav class="flex items-center gap-2 text-xs mb-10" style="color: var(--muted);">
      <a href="/" class="hover:text-[var(--accent)] transition-colors">Home</a>
      <span>/</span>
      <a href="/shop" class="hover:text-[var(--accent)] transition-colors">Shop</a>
      <span>/</span>
      <span class="truncate max-w-xs">{product.name}</span>
    </nav>

    <div class="grid md:grid-cols-2 gap-12 lg:gap-16">
      <div class="space-y-4">
        <div class="aspect-square rounded-2xl overflow-hidden border" style="border-color: var(--border);">
          {product.image_url ? (
            <img id="main-img" src={product.image_url} alt={product.name} class="w-full h-full object-cover" loading="eager" />
          ) : (
            <div class="w-full h-full flex items-center justify-center" style="background: #f5f0e8;"><svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" style="color: #c8b89a;"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></div>
          )}
        </div>
      </div>

      <div class="flex flex-col">
        <h1 class="text-3xl font-bold leading-tight mb-3" style="font-family: 'Fraunces', serif;">{product.name}</h1>
        <div class="flex items-center gap-3 mb-6">
          <span class="text-2xl font-bold">£{(product.price_pence / 100).toFixed(2)}</span>
          {product.compare_at_pence && product.compare_at_pence > product.price_pence && (
            <span class="text-lg line-through" style="color: var(--muted);">£{(product.compare_at_pence / 100).toFixed(2)}</span>
          )}
          {product.compare_at_pence && product.compare_at_pence > product.price_pence && (
            <span class="px-2 py-0.5 rounded text-xs font-bold text-white" style="background: var(--accent);">Save £{((product.compare_at_pence - product.price_pence) / 100).toFixed(2)}</span>
          )}
        </div>

        {product.description && <p class="text-sm leading-relaxed mb-6" style="color: var(--muted);">{product.description}</p>}

        {colors.length > 0 && (
          <div class="mb-5">
            <p class="text-sm font-semibold mb-2.5">Colour: <span id="selected-color" class="font-normal" style="color: var(--muted);">{colors[0]}</span></p>
            <div class="flex flex-wrap gap-2" id="color-btns">
              {colors.map((c, i) => (
                <button data-color={c} class="color-btn px-4 py-2 rounded-lg text-sm border transition-all" style={i === 0 ? 'border-color: var(--accent); color: var(--accent);' : 'border-color: var(--border);'}>{c}</button>
              ))}
            </div>
          </div>
        )}

        {sizes.length > 0 && (
          <div class="mb-6">
            <p class="text-sm font-semibold mb-2.5">Size: <span id="selected-size" class="font-normal" style="color: var(--muted);">{sizes[0]}</span></p>
            <div class="flex flex-wrap gap-2" id="size-btns">
              {sizes.map((s, i) => (
                <button data-size={s} class="size-btn px-4 py-2 rounded-lg text-sm border transition-all" style={i === 0 ? 'border-color: var(--accent); color: var(--accent);' : 'border-color: var(--border);'}>{s}</button>
              ))}
            </div>
          </div>
        )}

        <div class="flex gap-3 mb-6">
          <div class="flex items-center border rounded-lg overflow-hidden" style="border-color: var(--border);">
            <button id="qty-minus" class="px-3 py-3 hover:bg-gray-50 transition-colors text-lg">−</button>
            <span id="qty-display" class="px-4 py-3 text-sm font-medium w-12 text-center">1</span>
            <button id="qty-plus" class="px-3 py-3 hover:bg-gray-50 transition-colors text-lg">+</button>
          </div>
          <button
            id="add-to-cart-btn"
            class="flex-1 py-3.5 text-white font-semibold rounded-lg transition-all hover:opacity-90"
            style="background: var(--accent);"
            data-product-id={product.id}
            data-product-name={product.name}
            data-price-pence={product.price_pence}
            data-image-url={product.image_url || ""}
          >Add to cart</button>
        </div>

        <div class="space-y-2.5 py-5 border-t border-b" style="border-color: var(--border);">
          {[
            { icon: '🚚', text: 'Free UK shipping on orders over £50' },
            { icon: '↩️', text: '30-day returns — no questions asked' },
            { icon: '🌿', text: 'Water-based inks, ethically printed' },
          ].map(item => (
            <div class="flex items-center gap-3 text-sm" style="color: var(--muted);"><span>{item.icon}</span><span>{item.text}</span></div>
          ))}
        </div>

        {product.body_html && <div class="mt-6 prose prose-sm max-w-none" style="color: var(--muted);" set:html={safeHtml(product.body_html)} />}
      </div>
    </div>

    <div class="mt-20 pt-12 border-t" style="border-color: var(--border);">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold" style="font-family: 'Fraunces', serif;">More from the collection</h2>
        <a href="/shop" class="text-sm font-medium" style="color: var(--accent);">View all →</a>
      </div>
    </div>
  </div>

  <script define:vars={{ product, variants }}>
    let qty = 1;
    let selectedColor = variants[0]?.color || '';
    let selectedSize = variants[0]?.size || '';
    document.getElementById('qty-minus')?.addEventListener('click', () => { if (qty > 1) { qty--; document.getElementById('qty-display').textContent = String(qty); } });
    document.getElementById('qty-plus')?.addEventListener('click', () => { qty++; document.getElementById('qty-display').textContent = String(qty); });
    document.querySelectorAll('.color-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        selectedColor = btn.dataset.color || '';
        document.getElementById('selected-color').textContent = selectedColor;
        document.querySelectorAll('.color-btn').forEach(b => { b.style.borderColor = '#e0d8cc'; b.style.color = '#1a1209'; });
        btn.style.borderColor = 'var(--accent)'; btn.style.color = 'var(--accent)';
      });
    });
    document.querySelectorAll('.size-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        selectedSize = btn.dataset.size || '';
        document.getElementById('selected-size').textContent = selectedSize;
        document.querySelectorAll('.size-btn').forEach(b => { b.style.borderColor = '#e0d8cc'; b.style.color = '#1a1209'; });
        btn.style.borderColor = 'var(--accent)'; btn.style.color = 'var(--accent)';
      });
    });
    document.getElementById('add-to-cart-btn')?.addEventListener('click', () => {
      const btn = document.getElementById('add-to-cart-btn');
      const matchingVariant = variants.find((v) => v.color === selectedColor && v.size === selectedSize);
      const variantSku = matchingVariant?.sku || '';
      const cart = JSON.parse(localStorage.getItem('ht_cart') || '[]');
      const existingIdx = cart.findIndex((i) => i.product_id === product.id && i.variant_sku === variantSku);
      if (existingIdx >= 0) { cart[existingIdx].qty += qty; }
      else { cart.push({ product_id: product.id, qty, variant_sku: variantSku, name: product.name + (selectedColor ? ` — ${selectedColor}` : '') + (selectedSize ? ` / ${selectedSize}` : ''), price_pence: product.price_pence, image_url: product.image_url || '', color: selectedColor, size: selectedSize }); }
      localStorage.setItem('ht_cart', JSON.stringify(cart));
      window.dispatchEvent(new Event('cart:updated'));
      btn.textContent = 'Added! ✓'; btn.style.background = '#16a34a';
      setTimeout(() => { btn.textContent = 'Add to cart'; btn.style.background = 'var(--accent)'; }, 2000);
    });
  </script>
</Base>
