---
import Base from "../layouts/Base.astro";
import { serverClient } from "../lib/supabase";

const sb = serverClient();
const { data: products } = await sb
  .from("products")
  .select("id, slug, name, description, price_pence, compare_at_pence, currency, image_url, tags")
  .not("published_at", "is", null)
  .order("created_at", { ascending: false });

const { data: categories } = await sb
  .from("categories")
  .select("id, slug, name")
  .not("published_at", "is", null)
  .order("sort_order");

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Harmony Threads Shop",
  "url": `${Astro.site || ""}shop`,
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": (products ?? []).map((p, i) => ({
      "@type": "ListItem", "position": i + 1,
      "url": `${Astro.site || ""}product/${p.slug}`, "name": p.name,
    })),
  },
};
---

<Base
  title="Shop Vintage Band T-Shirts | Harmony Threads"
  description="Browse the full Harmony Threads collection — vintage-inspired graphic band tees in premium 180gsm cotton. Free UK shipping on orders over £50."
  structuredData={collectionSchema}
>
  <div class="max-w-7xl mx-auto px-6 py-16">
    <nav class="flex items-center gap-2 text-xs mb-8" style="color: var(--muted);">
      <a href="/" class="hover:text-[var(--accent)] transition-colors">Home</a><span>/</span><span>Shop</span>
    </nav>
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-10">
      <div>
        <h1 class="text-4xl font-bold" style="font-family: 'Fraunces', serif;">The collection</h1>
        <p class="mt-2 text-sm" style="color: var(--muted);">{(products ?? []).length} product{(products ?? []).length !== 1 ? 's' : ''}</p>
      </div>
      {categories && categories.length > 0 && (
        <div class="flex flex-wrap gap-2">
          <a href="/shop" class="px-4 py-1.5 rounded-full text-xs font-medium border transition-all hover:bg-[var(--accent)] hover:text-white hover:border-[var(--accent)]" style="border-color: var(--border);">All</a>
          {categories.map(c => (<a href={`/shop?category=${c.slug}`} class="px-4 py-1.5 rounded-full text-xs font-medium border transition-all hover:bg-[var(--accent)] hover:text-white hover:border-[var(--accent)]" style="border-color: var(--border);">{c.name}</a>))}
        </div>
      )}
    </div>
    {!products || products.length === 0 ? (
      <div class="text-center py-24">
        <p class="text-lg" style="color: var(--muted);">Products coming soon — sign up to hear first.</p>
        <a href="/#newsletter" class="mt-6 inline-flex items-center gap-2 px-6 py-3 rounded-lg text-white font-medium" style="background: var(--accent);">Join the list</a>
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {(products ?? []).map((p) => (
          <a href={`/product/${p.slug}`} class="group rounded-xl overflow-hidden border transition-all hover:-translate-y-1 hover:shadow-lg" style="border-color: var(--border); background: white;">
            <div class="aspect-square overflow-hidden bg-gray-50 relative">
              {p.image_url ? (
                <img src={p.image_url} alt={p.name} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
              ) : (
                <div class="w-full h-full flex items-center justify-center" style="background: #f5f0e8;"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" style="color: #c8b89a;"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></div>
              )}
              {p.compare_at_pence && p.compare_at_pence > p.price_pence && (<div class="absolute top-3 left-3 px-2 py-1 rounded text-xs font-bold text-white" style="background: var(--accent);">Sale</div>)}
            </div>
            <div class="p-5">
              <h2 class="font-semibold text-sm leading-snug mb-2">{p.name}</h2>
              {p.description && <p class="text-xs leading-relaxed mb-3 line-clamp-2" style="color: var(--muted);">{p.description}</p>}
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-2">
                  <span class="font-bold">£{(p.price_pence / 100).toFixed(2)}</span>
                  {p.compare_at_pence && p.compare_at_pence > p.price_pence && (<span class="text-xs line-through" style="color: var(--muted);">£{(p.compare_at_pence / 100).toFixed(2)}</span>)}
                </div>
                <span class="text-xs font-medium px-2 py-1 rounded-full" style="background: rgba(184,92,56,0.1); color: var(--accent);">View →</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</Base>
