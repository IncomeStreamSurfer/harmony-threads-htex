---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { serverClient } from "../../../lib/supabase";

export const prerender = false;

const sb = serverClient();
const { data: orders } = await sb
  .from("orders")
  .select("id, stripe_session_id, customer_email, amount_total_pence, currency, status, created_at")
  .order("created_at", { ascending: false })
  .limit(50);
---

<AdminLayout title="Orders">
  {!orders || orders.length === 0 ? (
    <div style="text-align:center; padding:64px 0; background:white; border:1px solid #e0d8cc; border-radius:12px;">
      <p style="font-size:14px; color:#6b5e4e;">No orders yet. Your first sale will appear here.</p>
    </div>
  ) : (
    <div style="background:white; border:1px solid #e0d8cc; border-radius:12px; overflow:hidden;">
      <table style="width:100%; border-collapse:collapse; font-size:13px;">
        <thead>
          <tr style="border-bottom:1px solid #e0d8cc; background:#faf7f2;">
            <th style="text-align:left; padding:12px 16px; font-weight:500; color:#6b5e4e;">Customer</th>
            <th style="text-align:left; padding:12px 16px; font-weight:500; color:#6b5e4e;">Amount</th>
            <th style="text-align:left; padding:12px 16px; font-weight:500; color:#6b5e4e;">Status</th>
            <th style="text-align:left; padding:12px 16px; font-weight:500; color:#6b5e4e;">Date</th>
          </tr>
        </thead>
        <tbody>
          {orders.map(o => (
            <tr style="border-bottom:1px solid #e0d8cc;">
              <td style="padding:12px 16px;">
                <p style="font-weight:500; margin:0;">{o.customer_email ?? "Guest"}</p>
                <p style="font-size:11px; font-family:monospace; color:#6b5e4e; margin:0;">{(o.stripe_session_id ?? "").slice(-12)}</p>
              </td>
              <td style="padding:12px 16px; font-weight:600;">£{((o.amount_total_pence ?? 0) / 100).toFixed(2)}</td>
              <td style="padding:12px 16px;">
                <span style={`padding:2px 8px; border-radius:20px; font-size:11px; font-weight:600; ${o.status === 'paid' ? 'color:#15803d; background:#dcfce7;' : 'color:#b45309; background:#fef3c7;'}`}>{o.status}</span>
              </td>
              <td style="padding:12px 16px; color:#6b5e4e;">{new Date(o.created_at).toLocaleDateString('en-GB')}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}
</AdminLayout>
