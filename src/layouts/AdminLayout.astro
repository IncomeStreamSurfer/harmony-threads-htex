---
import "../styles/global.css";

interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} — Admin | Harmony Threads</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@400;600;700&family=Manrope:wght@400;500;600&display=swap" rel="stylesheet" />
  <meta name="robots" content="noindex, nofollow" />
</head>
<body style="background:#f8f5f0; font-family: 'Manrope', sans-serif;">
  <div style="min-height:100vh; display:flex;">
    <aside style="width:224px; flex-shrink:0; border-right:1px solid #2d2018; display:flex; flex-direction:column; background:#1a1209;">
      <div style="padding:20px; border-bottom:1px solid #2d2018;">
        <a href="/" style="color:white; font-weight:700; text-decoration:none; font-family:'Fraunces',serif;">Harmony Threads</a>
        <p style="font-size:12px; color:rgba(255,255,255,0.4); margin:2px 0 0;">Admin</p>
      </div>
      <nav style="flex:1; padding:12px;">
        {[
          { href: '/admin', label: 'Dashboard', icon: '⊞' },
          { href: '/admin/products', label: 'Products', icon: '👕' },
          { href: '/admin/pages', label: 'Pages', icon: '📄' },
          { href: '/admin/orders', label: 'Orders', icon: '📦' },
          { href: '/admin/content', label: 'Blog', icon: '✍️' },
        ].map(item => (
          <a href={item.href} style="display:flex; align-items:center; gap:10px; padding:8px 12px; border-radius:8px; font-size:14px; color:rgba(255,255,255,0.7); text-decoration:none; margin-bottom:2px;">
            <span>{item.icon}</span>{item.label}
          </a>
        ))}
      </nav>
      <div style="padding:20px; border-top:1px solid #2d2018;">
        <a href="/" style="font-size:12px; color:rgba(255,255,255,0.4); text-decoration:none;">← Back to site</a>
      </div>
    </aside>
    <main style="flex:1; display:flex; flex-direction:column; min-height:100vh;">
      <header style="height:56px; border-bottom:1px solid #e0d8cc; padding:0 24px; display:flex; align-items:center; background:white;">
        <h1 style="font-size:14px; font-weight:600; margin:0;">{title}</h1>
      </header>
      <div style="flex:1; padding:24px;">
        <slot />
      </div>
    </main>
  </div>
</body>
</html>
