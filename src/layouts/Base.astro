---
import SEOHead from "../components/SEOHead.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
  author?: string;
  publishDate?: string;
  modifiedDate?: string;
  tags?: string[];
  structuredData?: object | object[];
  noindex?: boolean;
}

const props = Astro.props;

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Harmony Threads",
  "url": Astro.site?.toString() || "https://harmony-threads-htex.vercel.app",
  "logo": (Astro.site?.toString() || "") + "/favicon.svg",
  "sameAs": []
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <SEOHead {...props} structuredData={[orgSchema, ...(Array.isArray(props.structuredData) ? props.structuredData : props.structuredData ? [props.structuredData] : [])]} />
  </head>
  <body class="min-h-screen flex flex-col">
    <header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
      <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 group">
          <span class="text-2xl font-bold tracking-tight" style="font-family: 'Fraunces', serif; color: var(--ink);">Harmony Threads</span>
        </a>
        <nav class="hidden md:flex items-center gap-8">
          <a href="/shop" class="text-sm font-medium hover:text-[var(--accent)] transition-colors" style="color: var(--muted);">Shop</a>
          <a href="/#story" class="text-sm font-medium hover:text-[var(--accent)] transition-colors" style="color: var(--muted);">Our Story</a>
          <a href="/about" class="text-sm font-medium hover:text-[var(--accent)] transition-colors" style="color: var(--muted);">About</a>
          <a href="/contact" class="text-sm font-medium hover:text-[var(--accent)] transition-colors" style="color: var(--muted);">Contact</a>
        </nav>
        <div class="flex items-center gap-4">
          <button id="cart-btn" class="relative p-2 hover:opacity-70 transition-opacity" aria-label="Shopping cart">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
            <span id="cart-count" class="absolute -top-1 -right-1 w-5 h-5 rounded-full text-white text-xs flex items-center justify-center font-bold hidden" style="background: var(--accent);">0</span>
          </button>
          <button id="mobile-menu-btn" class="md:hidden p-2" aria-label="Menu">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          </button>
        </div>
      </div>
      <div id="mobile-nav" class="hidden md:hidden border-t px-6 py-4 space-y-3" style="background: var(--paper); border-color: var(--border);">
        <a href="/shop" class="block text-sm font-medium py-1" style="color: var(--muted);">Shop</a>
        <a href="/#story" class="block text-sm font-medium py-1" style="color: var(--muted);">Our Story</a>
        <a href="/about" class="block text-sm font-medium py-1" style="color: var(--muted);">About</a>
        <a href="/contact" class="block text-sm font-medium py-1" style="color: var(--muted);">Contact</a>
      </div>
    </header>

    <main class="flex-1 pt-16"><slot /></main>

    <div id="cart-overlay" class="fixed inset-0 bg-black/40 z-40 hidden" aria-hidden="true"></div>
    <aside id="cart-drawer" class="fixed top-0 right-0 h-full w-full max-w-sm z-50 shadow-2xl transform translate-x-full transition-transform duration-300 flex flex-col" style="background: var(--paper);">
      <div class="flex items-center justify-between px-6 py-5 border-b" style="border-color: var(--border);">
        <h2 class="text-lg font-semibold" style="font-family: 'Fraunces', serif;">Your cart</h2>
        <button id="cart-close" class="p-1 hover:opacity-60 transition-opacity"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
      </div>
      <div id="cart-items" class="flex-1 overflow-y-auto px-6 py-4 space-y-4">
        <p id="cart-empty" class="text-sm text-center py-12" style="color: var(--muted);">Your cart is empty</p>
      </div>
      <div class="px-6 py-5 border-t" style="border-color: var(--border);">
        <div class="flex justify-between text-sm font-medium mb-4"><span>Subtotal</span><span id="cart-total">£0.00</span></div>
        <button id="checkout-btn" class="w-full py-3.5 text-white font-semibold rounded-lg transition-all hover:opacity-90 disabled:opacity-40" style="background: var(--accent);">Proceed to checkout</button>
        <p class="text-xs text-center mt-3" style="color: var(--muted);">Secure checkout via Stripe</p>
      </div>
    </aside>

    <footer class="mt-20 border-t py-12" style="border-color: var(--border);">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-10">
          <div class="md:col-span-2">
            <span class="text-xl font-bold" style="font-family: 'Fraunces', serif;">Harmony Threads</span>
            <p class="mt-3 text-sm leading-relaxed" style="color: var(--muted);">Wear the music that shaped you. Vintage-inspired band tees for those who know the difference between a riff and a hook.</p>
          </div>
          <div>
            <h3 class="text-sm font-semibold mb-3 uppercase tracking-wider" style="color: var(--muted);">Shop</h3>
            <ul class="space-y-2 text-sm">
              <li><a href="/shop" class="hover:text-[var(--accent)] transition-colors" style="color: var(--muted);">All products</a></li>
              <li><a href="/shop?type=graphic-shirt" class="hover:text-[var(--accent)] transition-colors" style="color: var(--muted);">Graphic tees</a></li>
            </ul>
          </div>
          <div>
            <h3 class="text-sm font-semibold mb-3 uppercase tracking-wider" style="color: var(--muted);">Company</h3>
            <ul class="space-y-2 text-sm">
              <li><a href="/about" class="hover:text-[var(--accent)] transition-colors" style="color: var(--muted);">About us</a></li>
              <li><a href="/contact" class="hover:text-[var(--accent)] transition-colors" style="color: var(--muted);">Contact</a></li>
              <li><a href="/blog" class="hover:text-[var(--accent)] transition-colors" style="color: var(--muted);">Journal</a></li>
            </ul>
          </div>
        </div>
        <div class="border-t pt-6 flex flex-col md:flex-row justify-between items-center gap-4" style="border-color: var(--border);">
          <p class="text-xs" style="color: var(--muted);">© 2026 Harmony Threads. All rights reserved.</p>
          <p class="text-xs" style="color: var(--muted);">Made with love for music</p>
        </div>
      </div>
    </footer>

    <script>
      const header = document.getElementById('site-header');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 60) { header?.classList.add('bg-[#faf7f2]/95', 'backdrop-blur-sm', 'border-b'); header?.style && (header.style.borderColor = '#e0d8cc'); }
        else { header?.classList.remove('bg-[#faf7f2]/95', 'backdrop-blur-sm', 'border-b'); }
      });
      document.getElementById('mobile-menu-btn')?.addEventListener('click', () => { document.getElementById('mobile-nav')?.classList.toggle('hidden'); });
      type CartItem = { product_id: string; qty: number; variant_sku?: string; name: string; price_pence: number; image_url?: string; color?: string; size?: string };
      function getCart(): CartItem[] { try { return JSON.parse(localStorage.getItem('ht_cart') || '[]'); } catch { return []; } }
      function saveCart(c: CartItem[]) { localStorage.setItem('ht_cart', JSON.stringify(c)); }
      function updateCartUI() {
        const cart = getCart();
        const total = cart.reduce((s, i) => s + i.price_pence * i.qty, 0);
        const count = cart.reduce((s, i) => s + i.qty, 0);
        const countEl = document.getElementById('cart-count');
        const totalEl = document.getElementById('cart-total');
        const emptyEl = document.getElementById('cart-empty');
        const itemsEl = document.getElementById('cart-items');
        if (countEl) { countEl.textContent = String(count); count > 0 ? countEl.classList.remove('hidden') : countEl.classList.add('hidden'); }
        if (totalEl) totalEl.textContent = `£${(total/100).toFixed(2)}`;
        if (itemsEl && emptyEl) {
          if (cart.length === 0) { emptyEl.classList.remove('hidden'); }
          else {
            emptyEl.classList.add('hidden');
            itemsEl.querySelectorAll('.cart-line').forEach(e => e.remove());
            cart.forEach((item, idx) => {
              const div = document.createElement('div');
              div.className = 'cart-line flex gap-3 py-3 border-b last:border-0';
              div.style.borderColor = '#e0d8cc';
              div.innerHTML = `${item.image_url ? `<img src="${item.image_url}" alt="${item.name}" class="w-16 h-16 object-cover rounded" />` : ''}<div class="flex-1 min-w-0"><p class="text-sm font-medium truncate">${item.name}</p>${item.color || item.size ? `<p class="text-xs mt-0.5" style="color:#6b5e4e;">${[item.size, item.color].filter(Boolean).join(' / ')}</p>` : ''}<div class="flex items-center gap-2 mt-1.5"><button class="qty-btn w-6 h-6 border rounded text-sm flex items-center justify-center" data-idx="${idx}" data-delta="-1" style="border-color:#e0d8cc;">−</button><span class="text-sm w-4 text-center">${item.qty}</span><button class="qty-btn w-6 h-6 border rounded text-sm flex items-center justify-center" data-idx="${idx}" data-delta="1" style="border-color:#e0d8cc;">+</button></div></div><div class="text-sm font-semibold shrink-0">£${((item.price_pence * item.qty)/100).toFixed(2)}</div>`;
              itemsEl.appendChild(div);
            });
            itemsEl.querySelectorAll('.qty-btn').forEach(btn => {
              btn.addEventListener('click', () => {
                const i = parseInt((btn as HTMLElement).dataset.idx || '0');
                const delta = parseInt((btn as HTMLElement).dataset.delta || '0');
                const c = getCart(); c[i].qty += delta; if (c[i].qty <= 0) c.splice(i, 1); saveCart(c); updateCartUI();
              });
            });
          }
        }
      }
      function openCart() { document.getElementById('cart-drawer')?.classList.remove('translate-x-full'); document.getElementById('cart-overlay')?.classList.remove('hidden'); }
      function closeCart() { document.getElementById('cart-drawer')?.classList.add('translate-x-full'); document.getElementById('cart-overlay')?.classList.add('hidden'); }
      document.getElementById('cart-btn')?.addEventListener('click', openCart);
      document.getElementById('cart-close')?.addEventListener('click', closeCart);
      document.getElementById('cart-overlay')?.addEventListener('click', closeCart);
      document.getElementById('checkout-btn')?.addEventListener('click', async () => {
        const cart = getCart(); if (!cart.length) return;
        const btn = document.getElementById('checkout-btn') as HTMLButtonElement;
        if (btn) { btn.disabled = true; btn.textContent = 'Redirecting…'; }
        try {
          const res = await fetch('/api/checkout', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ items: cart.map(i => ({ product_id: i.product_id, qty: i.qty, variant_sku: i.variant_sku })) }) });
          const { url, error } = await res.json();
          if (error || !url) throw new Error(error || 'Checkout failed');
          window.location.href = url;
        } catch (e: any) {
          alert(e.message || 'Checkout failed. Please try again.');
          if (btn) { btn.disabled = false; btn.textContent = 'Proceed to checkout'; }
        }
      });
      window.addEventListener('cart:updated', updateCartUI);
      updateCartUI();
    </script>
  </body>
</html>
